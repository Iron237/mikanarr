# 镜像构建上下文裁剪:只保留 backend 源码 + frontend 源码,其余一律排除
# (防止把 .env/cookie/数据/虚拟环境/依赖/截图等带进镜像,既泄密又拖慢构建)
.git
.gitignore
**/__pycache__/
**/*.pyc
.pytest_cache/

# 运行时数据 / 凭据 / 本地素材(绝不入镜像)
data/
backend/data/
.env
*.env
!.env.example
mikan*cookie*.json
*cookie*.json
.probe-qb/
*.png

# 依赖与构建产物(镜像内会重新安装/构建)
backend/.venv/
frontend/node_modules/
frontend/dist/

# 本地导入源 / 试用栈 / 调试脚本 / 文档(运行不需要)
import/
ab-trial/
_*.py
scripts/
docs/
backend/tests/
release/
dist/
